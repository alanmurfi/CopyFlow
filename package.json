{
  "name": "copyflow",
  "version": "0.1.0",
  "description": "CopyFlow — Clipboard history manager for Chrome",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mantine/core": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@tabler/icons-react": "^3.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@wxt-dev/module-react": "^1.1.0",
    "postcss": "^8.4.0",
    "postcss-preset-mantine": "^1.17.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wxt": "^0.20.0"
  }
}
